    ]
  },
  {
    "key":         "example_tame_frantic",
    "name":        "Tame Frantic",
    "description": "Halve the tempo then apply a light performance pass for device-safe output.",
    "structural":  true,
    "steps": [
      { "transform": "halve_tempo",   "params": {} },
      { "transform": "performance",   "params": { "max_velocity": 0.32, "reversal_soften": 0.50 } }
    ]
  }
]
