[
  {
    "key":         "example_center_lift",
    "name":        "Center + Lift",
    "description": "Recenters displaced motion then gently amplifies — good for drift or half-stroke phrases.",
    "structural":  false,
    "steps": [
      { "transform": "recenter",        "params": { "target_center": 50  } },
      { "transform": "amplitude_scale", "params": { "scale": 1.5         } },
